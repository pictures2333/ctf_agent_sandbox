{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "ghidra_mcp": {
            "type": "local",
            "command": ["python3", "/mcp/ghidra_mcp/bridge_mcp_ghidra.py", "--ghidra-server", "http://host.docker.internal:8080"],
            "enabled": true
        },
        "mcp_terminal": {
            "type": "remote",
            "url": "http://127.0.0.1:8000/mcp",
            "enabled": true
        }
    }
}